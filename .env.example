PORT=3000
NODE_ENV=production
# Default SQL port used by Fabric SQL endpoints, Fabric Lakehouse SQL endpoints, and SQL Server.
DB_PORT=1433
DB_CONNECTION_TIMEOUT_MS=30000
DB_REQUEST_TIMEOUT_MS=120000
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CACHE_TTL_MS=600000

# Query/result safety limits.
WRITE_PREVIEW_LIMIT=10
HEIGHTENED_CONFIRM_LIMIT=3
CONFIRMATION_TTL_MS=300000
RESPONSE_ROW_LIMIT=250
MAX_QUERY_LENGTH=50000
MAX_PROCEDURE_PARAM_LENGTH=4000

# Audit and local runtime storage.
# For hosted/internal use, place these paths on private persistent storage.
AUDIT_LOG_LIMIT=200
AUDIT_LOG_MAX_BYTES=1048576
AUDIT_LOCAL_ONLY=true
AUDIT_ACCESS_MODE=loopback
AUDIT_LOG_FILE=./audit-log.ndjson
APP_DATA_DIR=data
SAVED_CONNECTIONS_FILE=saved-connections.json
CONFIRMATION_STORE_FILE=.data/pending-confirmations.json

# Local desktop lifecycle.
# The hidden local server shuts down after this long without browser heartbeats.
APP_HEARTBEAT_GRACE_MS=7200000
APP_SHUTDOWN_DELAY_MS=2500
APP_LOCAL_SHUTDOWN_ENABLED=true
# Self-update is local-only and requires the app folder to be a Git checkout.
APP_SELF_UPDATE_ENABLED=true

# Browser/API request guardrails.
# Set ALLOW_LOCAL_MISSING_ORIGIN=false for hosted environments.
ALLOW_LOCAL_MISSING_ORIGIN=true
POST_RATE_LIMIT_MAX=90
POST_RATE_LIMIT_WINDOW_MS=60000

# Required for Fabric service-principal authentication.
# Never commit real values.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
